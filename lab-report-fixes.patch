index 0000000..ff806cc
--- /dev/null
+++ b/src/lib/labAuth.ts
@@ -0,0 +1,26 @@
+import { timingSafeEqual } from 'node:crypto';
+
+/**
+ * Lightweight ownership check for labs. Not a real auth system (no
+ * accounts, no sessions) — just a per-lab secret returned once at
+ * creation time and required to edit/delete that lab afterward, so a
+ * stranger who only has the public student share link can't tamper
+ * with it. See README "Adding BetterAuth" for the real, account-based fix.
+ */
+export function isValidEditToken(provided: string | null, actual: string): boolean {
+  if (!provided) return false;
+  const providedBuf = Buffer.from(provided);
+  const actualBuf = Buffer.from(actual);
+  // timingSafeEqual throws if lengths differ, so check that first
+  if (providedBuf.length !== actualBuf.length) return false;
+  return timingSafeEqual(providedBuf, actualBuf);
+}
+
+/** Strip the edit token before sending a lab back in any response that
+ * isn't the one-time creation response. */
+export function stripEditToken<T extends { editToken?: string }>(
+  lab: T,
+): Omit<T, 'editToken'> {
+  const { editToken: _editToken, ...rest } = lab;
+  return rest;
+}
diff --git a/src/lib/labEditTokens.ts b/src/lib/labEditTokens.ts
new file mode 100644
index 0000000..51163da
--- /dev/null
+++ b/src/lib/labEditTokens.ts
@@ -0,0 +1,39 @@
+'use client';
+
+// Edit tokens are returned once when a lab is created (see POST
+// /api/labs) and required afterward to update or delete that lab.
+// Stored client-side since there's no account system yet -- this is a
+// stopgap, not real auth (see README "Adding BetterAuth").
+
+const STORAGE_KEY = 'lab-edit-tokens'; // { [labId]: editToken }
+
+function readTokens(): Record<string, string> {
+  try {
+    if (typeof window === 'undefined') return {};
+    const raw = localStorage.getItem(STORAGE_KEY);
+    return raw ? JSON.parse(raw) : {};
+  } catch {
+    return {};
+  }
+}
+
+export function saveEditToken(labId: string, editToken: string): void {
+  try {
+    if (typeof window === 'undefined') return;
+    const tokens = readTokens();
+    tokens[labId] = editToken;
+    localStorage.setItem(STORAGE_KEY, JSON.stringify(tokens));
+  } catch {
+    // Quota exceeded or storage unavailable -- the lab still exists,
+    // the professor just won't be able to edit/delete it from this
+    // browser later without the link to recreate it.
+  }
+}
+
+export function getEditToken(labId: string): string | null {
+  return readTokens()[labId] ?? null;
+}
+
+export function getAllEditTokens(): string[] {
+  return Object.values(readTokens());
+}
diff --git a/src/lib/labValidation.ts b/src/lib/labValidation.ts
new file mode 100644
index 0000000..afccb9f
--- /dev/null
+++ b/src/lib/labValidation.ts
@@ -0,0 +1,30 @@
+import { LabFormValues } from '@/types';
+
+export const MAX_TITLE_LENGTH = 200;
+export const MAX_NAME_LENGTH = 100;
+export const MAX_CLASS_LENGTH = 100;
+export const MAX_QUESTION_LENGTH = 1000;
+export const MAX_QUESTIONS = 50;
+
+/** Returns an error message if the payload is invalid, or null if it's fine. */
+export function validateLabPayload(body: Partial<LabFormValues>): string | null {
+  const { title, professorName, className, questions } = body;
+
+  if (!title?.trim() || !professorName?.trim() || !className?.trim()) {
+    return 'title, professorName, and className are required';
+  }
+  if (title.length > MAX_TITLE_LENGTH) return 'Lab title is too long';
+  if (professorName.length > MAX_NAME_LENGTH) return 'Professor name is too long';
+  if (className.length > MAX_CLASS_LENGTH) return 'Class name is too long';
+  if (!Array.isArray(questions) || questions.length === 0) {
+    return 'At least one question is required';
+  }
+  if (questions.length > MAX_QUESTIONS) return `Maximum ${MAX_QUESTIONS} questions allowed`;
+
+  for (const q of questions) {
+    if (!q.text?.trim()) return 'All questions must have text';
+    if (q.text.length > MAX_QUESTION_LENGTH) return 'A question text is too long';
+  }
+
+  return null;
+}
