index 0000000..c1b5baf
--- /dev/null
+++ b/docker-compose.override.yml
@@ -0,0 +1,13 @@
+# Local development only. `docker compose` automatically merges this
+# file on top of docker-compose.yml when you run it from this directory
+# (no extra flag needed), so the MinIO console stays reachable at
+# http://localhost:9001 during local dev.
+#
+# Do NOT copy this file to a production host. The base docker-compose.yml
+# intentionally omits this port -- the MinIO console has no auth beyond
+# the root credentials in .env, so leaving it open in production is a
+# real exposure risk.
+services:
+  minio:
+    ports:
+      - "9001:9001"
